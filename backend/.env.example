# Environment Configuration
NODE_ENV=development

# Database Configuration
DATABASE_URL=postgresql://pms_user:pms_password@localhost:5432/pms_db
MONGODB_URL=mongodb://localhost:27017/pms_db
REDIS_URL=redis://localhost:6379/0
ELASTICSEARCH_URL=http://localhost:9200

# JWT Configuration
SECRET_KEY=your-secret-key-here-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# OAuth2 Configuration
OAUTH2_CLIENT_ID=your-client-id
OAUTH2_CLIENT_SECRET=your-client-secret

# AI/ML Configuration
AI_MODEL_PATH=./models
AI_SERVICE_URL=http://localhost:8001

# External Integrations
TABLEAU_API_URL=https://tableau.example.com/api
HRMS_API_URL=https://hrms.example.com/api
FMIS_API_URL=https://fmis.example.com/api
IVALUA_API_URL=https://ivalua.example.com/api
BMC_REMEDY_API_URL=https://remedy.example.com/api

# Email Configuration
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASSWORD=your-email-password

# File Storage
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE=10485760

# CORS Configuration
CORS_ORIGINS=http://localhost:3000,http://localhost:19006

# Monitoring
SENTRY_DSN=your-sentry-dsn-here
